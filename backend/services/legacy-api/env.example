# Copy to .env and export, or set in your shell. Never commit real secrets.

ENV=development
HTTP_PORT=8080

# PostgreSQL connection URL (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune?sslmode=disable

# HS256 secret for JWT access tokens (required in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h

# golang-migrate source (run API from backend directory so ./migrations resolves)
MIGRATIONS_PATH=file://migrations
