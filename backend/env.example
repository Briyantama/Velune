# Copy to .env / export in shell. Never commit real secrets.

ENV=development
LOG_FORMAT=dev

# Legacy API (services/legacy-api)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune_legacy?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h
MIGRATIONS_PATH=file://services/legacy-api/migrations
HTTP_PORT=8090

# API gateway upstreams (optional split stack)
AUTH_SERVICE_URL=http://127.0.0.1:8081
TRANSACTION_SERVICE_URL=http://127.0.0.1:8082
CATEGORY_SERVICE_URL=http://127.0.0.1:8083
BUDGET_SERVICE_URL=http://127.0.0.1:8084
REPORT_SERVICE_URL=http://127.0.0.1:8085
LEGACY_API_URL=http://127.0.0.1:8090
