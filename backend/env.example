# Copy to .env / export in shell. Never commit real secrets.

ENV=development
LOG_FORMAT=dev

# Legacy API (services/legacy-api)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune_legacy?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h
MIGRATIONS_PATH=file://services/legacy-api/migrations
HTTP_PORT=8090

# API gateway upstreams (optional split stack)
AUTH_SERVICE_URL=http://127.0.0.1:8081
TRANSACTION_SERVICE_URL=http://127.0.0.1:8082
CATEGORY_SERVICE_URL=http://127.0.0.1:8083
BUDGET_SERVICE_URL=http://127.0.0.1:8084
REPORT_SERVICE_URL=http://127.0.0.1:8085
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8086
LEGACY_API_URL=http://127.0.0.1:8090

# Internal admin control plane (admin-service on 8099; never expose publicly)
# Use the same ADMIN_INTERNAL_KEY on transaction-service, budget-service, and admin-service.
ADMIN_API_KEY=change-me-admin-api-key
ADMIN_INTERNAL_KEY=change-me-admin-internal-key
# Admin-service DB URLs (defaults match docker compose DB names)
TRANSACTION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune_transaction?sslmode=disable
BUDGET_DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune_budget?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/velune_notification?sslmode=disable

# Broker + notifications
BROKER_URL=amqp://guest:guest@127.0.0.1:5672/
BROKER_EXCHANGE=velune.events
BROKER_QUEUE=notification.overspend
BROKER_ROUTING_KEY=notification.overspend.requested
BROKER_DLX=velune.events.dlx
BROKER_DLQ=velune.events.dlq
BROKER_DLQ_ROUTING_KEY=velune.dlq
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRY=7
RETRY_BASE_DELAY_SECONDS=2
EMAIL_FROM=noreply@velune.local
